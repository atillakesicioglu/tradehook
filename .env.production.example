# ---------------------------------------------------------------------------
# TradeHook — production (.env on Hostinger VPS)
# Copy to .env next to docker-compose.prod.yml
# ---------------------------------------------------------------------------

# --- Docker Postgres (internal network) ---
POSTGRES_USER=tradehook
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=tradehook
DATABASE_URL=postgresql://tradehook:CHANGE_ME_STRONG_PASSWORD@postgres:5432/tradehook?schema=public

# --- Redis (internal) ---
REDIS_URL=redis://redis:6379

# --- Domain / URLs ---
WEB_ORIGIN=https://atikaiagents.cloud
API_URL=https://api.atikaiagents.cloud
WEBHOOK_PUBLIC_URL=https://api.atikaiagents.cloud
NEXT_PUBLIC_API_URL=https://api.atikaiagents.cloud

# --- Auth ---
DEV_MOCK_AUTH=true
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
NEXT_PUBLIC_DEV_MOCK_AUTH=true

# --- Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
ENCRYPTION_KEY=

# --- Trading ---
MOCK_TRADING=true
BINANCE_USE_TESTNET=true

# --- Ports (inside containers; Caddy exposes 80/443) ---
WEB_PORT=3000
API_PORT=3001
