# ---------------------------------------------------------------------------
# TradeHook environment configuration (local development)
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL via docker-compose) ---
# docker-compose maps the container's 5432 to host port 5433.
DATABASE_URL="postgresql://tradehook:tradehook@localhost:5433/tradehook?schema=public"

# --- Redis (BullMQ queue + realtime pub/sub) ---
REDIS_URL="redis://localhost:6379"

# --- Auth mode ---
# When true, the API exposes dev email/password auth and issues its own JWTs.
# Set to false once Firebase is configured (the API then verifies Firebase ID tokens).
DEV_MOCK_AUTH=true
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"

# --- Firebase Admin (server side, only needed when DEV_MOCK_AUTH=false) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the surrounding quotes and literal \n escapes for the private key.
FIREBASE_PRIVATE_KEY=

# --- Firebase Web SDK (client side, only needed when DEV_MOCK_AUTH=false) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# --- Encryption (Binance credentials at rest, AES-256-GCM) ---
# Must be 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Binance ---
# When true, the worker never calls Binance and creates fake successful orders.
MOCK_TRADING=true
# When true, use the Binance Spot Testnet (https://testnet.binance.vision).
BINANCE_USE_TESTNET=true

# --- Ports / URLs ---
WEB_PORT=3000
API_PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# --- TradingView webhooks (public tunnel) ---
# TradingView does NOT accept localhost or custom ports like :3001.
# It only allows HTTPS (port 443) or HTTP (port 80), and must reach your machine
# from the internet. For local dev, run a tunnel and paste the HTTPS URL here:
#
#   cloudflared tunnel --url http://localhost:3001
#   # or: ngrok http 3001
#
# Example (change every time the tunnel restarts unless you use a fixed domain):
# WEBHOOK_PUBLIC_URL=https://abc123.trycloudflare.com
WEBHOOK_PUBLIC_URL=
# Tells the web app which auth mode the API runs in.
NEXT_PUBLIC_DEV_MOCK_AUTH=true
